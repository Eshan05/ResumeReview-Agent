# App infrastructure
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3001
UPLOADTHING_TOKEN=
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# QStash Workflow. Use true with the local QStash development server only.
QSTASH_DEV=true
QSTASH_URL=http://localhost:8080
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
RESUME_REVIEW_WORKFLOW_FLOW_KEY=resume-review-workflow
RESUME_REVIEW_WORKFLOW_RATE=1
RESUME_REVIEW_WORKFLOW_RATE_PERIOD_SECONDS=60
RESUME_REVIEW_WORKFLOW_PARALLELISM=2

# Model providers
GROQ_API_KEY=
GROQ_REVIEW_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
CEREBRAS_SPECIALIST_MODEL=gpt-oss-120b
RESUME_SPECIALIST_PROVIDER=balanced
RESUME_SPECIALIST_FALLBACK_PROVIDER=groq
RESUME_SPECIALIST_MAX_OUTPUT_TOKENS=2000
GROQ_REVIEW_MAX_OUTPUT_TOKENS=6000

# Shared provider quota scheduler
PROVIDER_QUOTA_SCHEDULER_ENABLED=true
PROVIDER_QUOTA_RETENTION_DAYS=30
# Keep unset in Workflow/Vercel. CLI scripts set a bounded local wait themselves.
PROVIDER_QUOTA_WAIT_MAX_MS=

# Override these with the exact limits shown in each provider account.
CEREBRAS_QUOTA_RPM=5
CEREBRAS_QUOTA_TPM=30000
CEREBRAS_QUOTA_TPH=1000000
CEREBRAS_QUOTA_TPD=1000000
CEREBRAS_QUOTA_HEADROOM=0.8
GROQ_QUOTA_RPM=30
GROQ_QUOTA_TPM=12000
GROQ_QUOTA_RPD=1000
GROQ_QUOTA_TPD=100000
GROQ_QUOTA_HEADROOM=0.8
GROQ_ASK_QUOTA_HEADROOM=0.95
